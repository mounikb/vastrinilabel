<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money, shop: shop.name }}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-gift-card" style="background:{{ settings.color_background }};color:{{ settings.color_text }};font-family:{{ settings.font_body.family }},sans-serif">
  <main style="max-width:560px;margin:60px auto;padding:32px;text-align:center">
    <h1 style="font-family:{{ settings.font_heading.family }};font-size:2rem">{{ shop.name }} Gift Card</h1>
    <p style="font-size:2.6rem;color:{{ settings.color_primary }};font-family:{{ settings.font_heading.family }}">{{ gift_card.initial_value | money }}</p>
    {%- if gift_card.enabled == false or gift_card.expired -%}
      <p style="background:#f5d2d8;padding:12px;border-radius:8px">{{ 'gift_cards.issued.expired' | t }}</p>
    {%- endif -%}
    <div style="background:#fff;padding:24px;border:1px solid {{ settings.color_border }};border-radius:8px;margin:24px 0">
      <code style="font-size:1.2rem;letter-spacing:.1em">{{ gift_card.code | format_code }}</code>
    </div>
    <a href="{{ shop.url }}" class="btn btn--primary">Visit store</a>
    <p style="margin-top:24px"><a href="{{ gift_card.pass_url }}">Add to Apple Wallet</a></p>
  </main>
</body>
</html>
