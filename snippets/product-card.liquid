{%- comment -%}
  Renders a product card.
  Accepts: product (required), show_vendor (bool), show_quick (bool)
{%- endcomment -%}
{%- liquid
  assign first_image = product.featured_image
  assign second_image = product.images[1]
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif
  assign product_share_url = shop.url | append: product.url
-%}
<article
  class="product-card"
  data-price="{{ product.price }}"
  data-product-title="{{ product.title | escape }}"
  data-product-url="{{ product_share_url }}"
>
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title | escape }}">
    <div class="product-card__media">
    {%- if product.available == false -%}
      <span class="product-card__badge product-card__badge--soldout">{{ 'products.product.sold_out' | t }}</span>
    {%- elsif on_sale -%}
      <span class="product-card__badge">{{ 'products.product.on_sale' | t }}</span>
    {%- endif -%}
    {%- if first_image -%}
      <img src="{{ first_image | image_url: width: 600 }}" alt="{{ first_image.alt | default: product.title | escape }}" loading="lazy" width="600" height="800">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
    {%- endif -%}
    {%- if second_image -%}
      <img class="product-card__media--alt" src="{{ second_image | image_url: width: 600 }}" alt="" loading="lazy" width="600" height="800">
    {%- endif -%}
    {%- if show_quick -%}
      <span class="product-card__quick">{{ 'products.product.view_details' | t }}</span>
    {%- endif -%}
    </div>
    {%- if show_vendor -%}
      <div class="product-card__vendor">{{ product.vendor }}</div>
    {%- endif -%}
    <h3 class="product-card__title">{{ product.title }}</h3>
    <div class="product-card__price">
      {%- if on_sale -%}
        <span class="price--sale">{{ product.price | money }}</span>
        <span class="price--compare">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        <span>{{ product.price | money }}</span>
      {%- endif -%}
    </div>
  </a>
  <button type="button" class="product-card__share-trigger" data-share-product aria-label="Share {{ product.title | escape }}">
    {% render 'icon', icon: 'arrow-up-right' %}
  </button>
</article>
