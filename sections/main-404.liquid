{%- assign requested_path = request.path | downcase -%}

{%- if requested_path contains '/pages/about-us' or requested_path contains '/pages/about' -%}
  {% render 'page-about-vastrini' %}
{%- elsif requested_path contains '/pages/terms-and-conditions' or requested_path contains '/pages/terms-conditions' or requested_path contains '/pages/terms' -%}
  {% render 'page-terms-vastrini' %}
{%- else -%}
  <div class="center-page">
    <h1>404</h1>
    <h2>{{ 'general.404.title' | t }}</h2>
    <p style="color:var(--color-muted);max-width:420px">{{ 'general.404.subtext' | t }}</p>
    <a href="/" class="btn btn--primary mt-4">{{ 'general.404.link' | t }}</a>
  </div>
{%- endif -%}

{% schema %}
{ "name": "404", "settings": [] }
{% endschema %}
