{%- assign page_handle = page.handle | default: page.title | handle -%}

{%- if page_handle == 'about' or page_handle == 'about-us' -%}
  {% render 'page-about-vastrini' %}
{%- elsif page_handle == 'terms' or page_handle == 'terms-and-conditions' or page_handle == 'terms-conditions' -%}
  {% render 'page-terms-vastrini' %}
{%- else -%}
  <div class="rich-page">
    <h1>{{ page.title }}</h1>
    <div class="rich-content">{{ page.content }}</div>
  </div>
{%- endif -%}

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
