<section class="section">
  <div class="page-width">
    {%- liquid
      assign styled_heading = section.settings.heading
      assign styled_heading = styled_heading | replace: 'VIP community', '<em>VIP Community</em>'
      assign styled_heading = styled_heading | replace: 'VIP Community', '<em>VIP Community</em>'
    -%}
    <div class="newsletter-banner">
      <div class="newsletter-banner__media">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="1200" height="1200">
        {%- else -%}
          <div class="newsletter-banner__placeholder">
            <span class="newsletter-banner__placeholder-badge">The inner circle</span>
            <img src="{{ 'vastrini-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" width="360" height="104">
          </div>
        {%- endif -%}
        <span class="newsletter-banner__floating-label">
          <span>&larr;</span>
          <span>{{ section.settings.media_badge | default: 'The inner circle' }}</span>
        </span>
      </div>
      <div class="newsletter-banner__content">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 class="newsletter-banner__headline">{{ styled_heading }}</h2>
        <p>{{ section.settings.body }}</p>
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="newsletter-banner__cta">
            <span class="newsletter-banner__cta-icon">{% render 'icon', icon: 'arrow-up-right' %}</span>
            <span class="newsletter-banner__cta-copy">
              <strong>{{ section.settings.cta_text }}</strong>
              <small>{{ section.settings.cta_caption }}</small>
            </span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "media_badge", "label": "Media badge", "default": "The inner circle" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Exclusive community" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join our VIP community" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Get early access to new drops, exclusive offers, styling tips, and behind-the-scenes updates. Be part of the Vastrini inner circle." },
    { "type": "text", "id": "cta_text", "label": "Secondary CTA title", "default": "Join via WhatsApp" },
    { "type": "text", "id": "cta_caption", "label": "Secondary CTA caption", "default": "Exclusive updates. No spam. Leave anytime." },
    { "type": "url", "id": "cta_link", "label": "Secondary CTA link" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
