<section class="section">
  <div class="page-width">
    <div class="newsletter">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow" style="display:block;font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;margin-bottom:.6rem;opacity:.85">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body }}</p>
      {%- form 'customer', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter_form.email_placeholder' | t }}" required aria-label="Email">
        <button type="submit">{{ 'general.newsletter_form.submit' | t }}</button>
        {%- if form.posted_successfully? -%}<p style="margin-top:14px">{{ 'general.newsletter_form.confirmation' | t }}</p>{%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the club" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% off your first order" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Sign up for first access to new drops, edits, and members-only sales." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
