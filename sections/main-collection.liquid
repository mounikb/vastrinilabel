<div class="collection-banner">
  <div class="page-width">
    <div class="collection-banner__inner">
      <div class="collection-banner__content">
        <span class="collection-banner__eyebrow">Curated collection</span>
        <h1>{{ collection.title }}</h1>
      </div>
      <div class="collection-banner__meta">
        {%- if collection.description != blank -%}
          <p>{{ collection.description | strip_html | truncatewords: 30 }}</p>
        {%- else -%}
          <p>Every piece in this edit is selected to feel polished, wearable, and easy to style from day to night.</p>
        {%- endif -%}
        <div class="collection-banner__chips">
          <span>{{ collection.products_count }} pieces</span>
          <span>Fresh styling edit</span>
          <span>Effortless wardrobe energy</span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-width">
  <div class="collection-toolbar">
    <span class="collection-toolbar__count">{{ 'collections.general.items_with_count' | t: count: collection.products_count }}</span>
    <form class="collection-toolbar__form">
      <label for="SortBy">{{ 'collections.general.sort_by' | t }}</label>
      <select name="sort_by" id="SortBy" onchange="this.form.submit()">
        {%- assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-ascending,created-descending' | split: ',' -%}
        {%- for opt in sort_options -%}
          <option value="{{ opt }}" {% if collection.sort_by == opt or collection.default_sort_by == opt and collection.sort_by == blank %}selected{% endif %}>
            {{ opt | replace: '-', '_' | prepend: 'collections.sorting.' | t }}
          </option>
        {%- endfor -%}
      </select>
    </form>
  </div>

  {%- paginate collection.products by 24 -%}
    {%- if collection.products.size > 0 -%}
      <div class="product-grid product-grid--collection">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product, show_quick: true %}
        {%- endfor -%}
      </div>
      {% render 'pagination', paginate: paginate %}
    {%- else -%}
      <p style="text-align:center;padding:60px 0">{{ 'collections.general.no_matches' | t }}</p>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
