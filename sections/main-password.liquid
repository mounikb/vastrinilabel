<div class="password-page">
  <div class="password-page__inner">
    {%- if shop.password_message != blank -%}<p style="margin-bottom:24px;color:var(--color-muted)">{{ shop.password_message }}</p>{%- endif -%}
    <h1 style="font-size:2.4rem;color:var(--color-primary)">{{ shop.name }}</h1>
    <p style="color:var(--color-muted)">{{ 'general.password_page.opening_soon' | t }}</p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}<p style="color:var(--color-sale);margin-top:12px">Incorrect password</p>{%- endif -%}
      <input type="password" name="password" placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}" required>
      <button type="submit" class="btn btn--primary">{{ 'general.password_page.login_form_submit' | t }}</button>
    {%- endform -%}

    <p style="margin-top:32px;font-size:.8rem;color:var(--color-muted)">{{ 'general.password_page.admin_link_html' | t }}</p>
  </div>
</div>

{% schema %}
{ "name": "Password", "settings": [] }
{% endschema %}
