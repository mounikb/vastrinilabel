<section class="section">
  <div class="page-width">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="cgrid">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- assign img = block.settings.image | default: coll.image | default: coll.products.first.featured_image -%}
        <a href="{{ coll.url | default: '#' }}" class="cgrid__item" {{ block.shopify_attributes }}>
          {%- if img -%}
            <img src="{{ img | image_url: width: 800 }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="800" height="1000">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder' }}
          {%- endif -%}
          <div class="cgrid__label">
            {{ block.settings.label | default: coll.title }}
            <small>{{ block.settings.subtext | default: 'Shop now' }}</small>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook grid",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by edit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Curated collections" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image (overrides collection image)" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "Shop now" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook grid",
      "blocks": [
        { "type": "tile", "settings": { "label": "Dresses" } },
        { "type": "tile", "settings": { "label": "Tops" } },
        { "type": "tile", "settings": { "label": "Bottoms" } }
      ]
    }
  ]
}
{% endschema %}
