<div class="hero" data-hero>
  <div class="hero__slides">
    {%- for block in section.blocks -%}
      {%- assign slide_link = block.settings.link | default: block.settings.button_link -%}
      <div class="hero__slide" {{ block.shopify_attributes }}>
        {%- if slide_link != blank -%}
          <a class="hero__slide-link" href="{{ slide_link }}" aria-label="{{ block.settings.alt | default: shop.name | escape }}">
        {%- else -%}
          <div class="hero__slide-link" aria-label="{{ block.settings.alt | default: shop.name | escape }}">
        {%- endif -%}
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 2200 }}"
              alt="{{ block.settings.alt | escape }}"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
              width="2200"
              height="1200"
            >
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'hero__placeholder' }}
          {%- endif -%}
        {%- if slide_link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  {%- if section.blocks.size > 1 -%}
    <button class="hero__arrow hero__arrow--prev" aria-label="{{ 'general.accessibility.previous' | t }}">{% render 'icon', icon: 'arrow-left' %}</button>
    <button class="hero__arrow hero__arrow--next" aria-label="{{ 'general.accessibility.next' | t }}">{% render 'icon', icon: 'arrow-right' %}</button>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero slideshow",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Image description", "default": "Hero banner" },
        { "type": "url", "id": "link", "label": "Slide link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slideshow",
      "blocks": [{ "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
