<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- elsif block.type == 'text' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <div class="site-footer__text">{{ block.settings.body }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="site-footer__help">
        <h4>Need help?</h4>
        <ul class="site-footer__help-list">
          {%- if section.settings.primary_link_label != blank -%}
            <li><a href="{{ section.settings.primary_link | default: '/pages/contact' }}">{% render 'icon', icon: 'pin' %}<span>{{ section.settings.primary_link_label }}</span></a></li>
          {%- endif -%}
          {%- if section.settings.contact_email != blank -%}
            <li><a href="mailto:{{ section.settings.contact_email }}">{% render 'icon', icon: 'mail' %}<span>{{ section.settings.contact_email }}</span></a></li>
          {%- endif -%}
          {%- if section.settings.support_hours != blank -%}
            <li><span>{% render 'icon', icon: 'clock' %}<span>{{ section.settings.support_hours }}</span></span></li>
          {%- endif -%}
          <li><a href="/pages/contact">{% render 'icon', icon: 'arrow-up-right' %}<span>Contact us</span></a></li>
        </ul>
      </div>
    </div>

    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      <span class="site-footer__bottom-note">{{ shop.address.country.name }}</span>
      <div class="site-footer__social">
        {%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" aria-label="Facebook">{% render 'icon', icon: 'facebook' %}</a>{%- endif -%}
        {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" aria-label="Instagram">{% render 'icon', icon: 'instagram' %}</a>{%- endif -%}
        {%- if settings.social_youtube_link != blank -%}<a href="{{ settings.social_youtube_link }}" aria-label="YouTube">{% render 'icon', icon: 'youtube' %}</a>{%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}<a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest">{% render 'icon', icon: 'pinterest' %}</a>{%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Effortless contemporary fashion with a softer, more elevated point of view." },
    { "type": "text", "id": "contact_email", "label": "Contact email", "default": "hello@vastrinilabel.com" },
    { "type": "text", "id": "support_hours", "label": "Support hours", "default": "10:30 AM to 10:00 PM (All days)" },
    { "type": "text", "id": "location_title", "label": "Location title", "default": "Bengaluru flagship" },
    { "type": "textarea", "id": "location_body", "label": "Location body", "default": "Electronic City Phase 1,\nBengaluru 560100, India" },
    { "type": "text", "id": "primary_link_label", "label": "Primary link label", "default": "Get directions" },
    { "type": "url", "id": "primary_link", "label": "Primary link" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "Text block",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Help" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    }
  ],
  "default": {
    "settings": {},
    "blocks": [
      { "type": "menu", "settings": { "heading": "Shop" } },
      { "type": "menu", "settings": { "heading": "Help" } },
      { "type": "menu", "settings": { "heading": "Company" } }
    ]
  }
}
{% endschema %}
