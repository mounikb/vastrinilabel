{%- liquid
  assign footer_instagram_link = section.settings.instagram_link | default: settings.social_instagram_link | default: 'https://www.instagram.com/'
  assign footer_facebook_link = section.settings.facebook_link | default: settings.social_facebook_link | default: 'https://www.facebook.com/'
  assign footer_youtube_link = section.settings.youtube_link | default: settings.social_youtube_link | default: 'https://www.youtube.com/'
-%}

<footer class="site-footer site-footer--editorial">
  <div class="page-width">
    <div class="site-footer__layout">
      <div class="site-footer__brand">
        <div class="site-footer__contact-lines">
          {%- if section.settings.contact_email != blank -%}
            <p>Email: <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></p>
          {%- endif -%}
          {%- if section.settings.whatsapp_number != blank -%}
            <p>Whatsapp: <a href="{{ section.settings.whatsapp_link | default: '#' }}">{{ section.settings.whatsapp_number }}</a></p>
          {%- endif -%}
        </div>

        <a href="{{ section.settings.contact_page | default: '/pages/contact' }}" class="site-footer__contact-cta">
          <span>Contact Us</span>
          {% render 'icon', icon: 'arrow-up-right' %}
        </a>

        <div class="site-footer__social">
          <a href="{{ footer_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', icon: 'facebook' %}</a>
          <a href="{{ footer_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', icon: 'instagram' %}</a>
          <a href="{{ footer_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', icon: 'youtube' %}</a>
        </div>
      </div>

      <div class="site-footer__menu-col">
        <h4>{{ section.settings.help_heading }}</h4>
        <ul>
          {%- for link in section.settings.help_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="site-footer__menu-col">
        <h4>{{ section.settings.quick_links_heading }}</h4>
        <ul>
          {%- for link in section.settings.quick_links_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="site-footer__newsletter">
        <h4>{{ section.settings.newsletter_heading }}</h4>
        <p>{{ section.settings.newsletter_text }}</p>
        {%- form 'customer', class: 'site-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="site-footer__newsletter-input"
            placeholder="Enter email address"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            autocorrect="off"
            autocapitalize="off"
            required
          >
          <button type="submit" class="site-footer__newsletter-button">
            <span>Subscribe</span>
            {% render 'icon', icon: 'arrow-up-right' %}
          </button>
        {%- endform -%}
        <div class="site-footer__meta-row">
          <span class="site-footer__currency">INR</span>
          <button type="button" class="site-footer__backtotop" data-scroll-top aria-label="Back to top">
            {% render 'icon', icon: 'arrow-up-right' %}
          </button>
        </div>
      </div>
    </div>

    <div class="site-footer__bottomline">
      <span>&copy; {{ shop.name }} {{ 'now' | date: '%Y' }}</span>
      <div class="site-footer__payments">
        {%- for type in shop.enabled_payment_types -%}
          <span class="site-footer__payment-icon">{{ type | payment_type_svg_tag }}</span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "contact_email", "label": "Contact email", "default": "vastarathelabel@gmail.com" },
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp number", "default": "+91 6380 734 120" },
    { "type": "url", "id": "whatsapp_link", "label": "WhatsApp link" },
    { "type": "url", "id": "instagram_link", "label": "Instagram link" },
    { "type": "url", "id": "facebook_link", "label": "Facebook link" },
    { "type": "url", "id": "youtube_link", "label": "YouTube link" },
    { "type": "page", "id": "contact_page", "label": "Contact page" },
    { "type": "text", "id": "help_heading", "label": "Help heading", "default": "Help" },
    { "type": "link_list", "id": "help_menu", "label": "Help menu", "default": "footer" },
    { "type": "text", "id": "quick_links_heading", "label": "Quick links heading", "default": "Quick Links" },
    { "type": "link_list", "id": "quick_links_menu", "label": "Quick links menu", "default": "main-menu" },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Sign Up for Email" },
    { "type": "textarea", "id": "newsletter_text", "label": "Newsletter text", "default": "Sign up to get first dibs on new arrivals, sales, exclusive content, events and more!" }
  ]
}
{% endschema %}
