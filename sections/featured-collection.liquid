<section class="section">
  <div class="page-width">
    <div class="section-heading featured-carousel__heading">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <div class="featured-carousel__arrows" aria-hidden="true">
        <button type="button" class="featured-carousel__arrow" data-carousel-prev aria-label="Scroll left">
          {% render 'icon', icon: 'arrow-left' %}
        </button>
        <button type="button" class="featured-carousel__arrow" data-carousel-next aria-label="Scroll right">
          {% render 'icon', icon: 'arrow-right' %}
        </button>
      </div>
    </div>
    {%- liquid
      assign coll = blank
      assign collection_name_key = section.settings.collection_name | strip | downcase
      assign filter_tag_key = section.settings.filter_tag | strip | downcase

      if collection_name_key == 'all'
        assign coll = collections.all
      elsif collection_name_key != blank
        for candidate in collections
          assign candidate_title_key = candidate.title | strip | downcase
          assign candidate_handle_key = candidate.handle | strip | downcase
          if candidate_title_key == collection_name_key or candidate_handle_key == collection_name_key
            assign coll = candidate
            break
          endif
        endfor
      endif

      if coll == blank and section.settings.collection != blank
        assign coll = collections[section.settings.collection]
      endif
      if coll == blank or coll.empty?
        assign coll = collections.frontpage
      endif
      if coll == blank or coll.empty?
        assign coll = collections.all
      endif
      assign rendered_count = 0
      assign view_all_url = coll.url
      if filter_tag_key != blank
        assign filter_tag_handle = filter_tag_key | handle
        assign view_all_url = coll.url | append: '/' | append: filter_tag_handle
      endif
    -%}
    <div class="featured-carousel" data-product-carousel>
      <div class="featured-carousel__viewport" data-carousel-viewport>
        <div class="featured-carousel__track" data-carousel-track>
      {%- if coll.products.size > 0 -%}
        {%- for product in coll.products -%}
          {%- liquid
            assign show_product = true
            if filter_tag_key != blank
              assign show_product = false
              for tag in product.tags
                assign tag_key = tag | strip | downcase
                if tag_key == filter_tag_key
                  assign show_product = true
                  break
                endif
              endfor
            endif
          -%}
          {%- if show_product -%}
            {% render 'product-card', product: product, show_quick: true %}
            {%- assign rendered_count = rendered_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if rendered_count == 0 -%}
        <p class="featured-carousel__empty">
          No matching products yet. Add products to this collection and tag them in Shopify admin.
        </p>
      {%- endif -%}
        </div>
      </div>
    </div>
    {%- if section.settings.show_view_all and coll != blank and rendered_count > 0 -%}
      <div class="text-center mt-8">
        <a href="{{ view_all_url }}" class="btn btn--secondary">{{ 'collections.general.view_all' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bestsellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by you" },
    { "type": "text", "id": "collection_name", "label": "Collection name (case-insensitive)", "default": "Home Page" },
    { "type": "text", "id": "filter_tag", "label": "Optional product tag filter (case-insensitive)" },
    { "type": "collection", "id": "collection", "label": "Fallback collection" },
    { "type": "range", "id": "product_count", "label": "Products to show", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show \"View all\" button", "default": true }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
