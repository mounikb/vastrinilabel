<section class="section--sm">
  <div class="page-width" style="text-align:{{ section.settings.align }};max-width:760px">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow" style="display:block;font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--color-primary);font-weight:600;margin-bottom:.8rem">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<div class="rich-content">{{ section.settings.body }}</div>{%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <p style="margin-top:24px"><a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--primary">{{ section.settings.button_text }}</a></p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A note from us" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Beautiful, considered fashion - designed in-house and made to last.</p>" },
    { "type": "text", "id": "button_text", "label": "Button text" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "align", "label": "Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
