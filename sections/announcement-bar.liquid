<div class="announcement-bar" role="region" aria-label="Announcement">
  {%- if section.settings.text != blank -%}
    {%- if section.settings.link != blank -%}<a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
    {%- else -%}{{ section.settings.text }}{%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "New season arrivals are live now" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
