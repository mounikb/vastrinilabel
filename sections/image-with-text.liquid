<section class="section features-section" style="background:{{ section.settings.bg_color }}">
  <div class="page-width">
    <div class="features-banner">
      <div class="features-banner__intro">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <div class="features-banner__copy">{{ section.settings.body }}</div>
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--primary">{{ section.settings.button_text }}</a>
        {%- endif -%}
      </div>
      <div class="features-banner__grid">
        <article class="features-banner__card">
          <span class="features-banner__icon">{% render 'icon', icon: 'diamond' %}</span>
          <strong>100% Handpicked Quality</strong>
          <p>Chosen for flattering fits, polished finishing, and wardrobe-ready ease.</p>
        </article>
        <article class="features-banner__card">
          <span class="features-banner__icon">{% render 'icon', icon: 'truck' %}</span>
          <strong>2-5 Day Delivery</strong>
          <p>Fast pan-India shipping with smooth tracking and careful packaging.</p>
        </article>
        <article class="features-banner__card">
          <span class="features-banner__icon">{% render 'icon', icon: 'shield' %}</span>
          <strong>Secure Checkout</strong>
          <p>Trusted payments, protected data, and a checkout that feels effortless.</p>
        </article>
        <article class="features-banner__card">
          <span class="features-banner__icon">{% render 'icon', icon: 'headset' %}</span>
          <strong>Personal Support</strong>
          <p>Quick help when you need sizing advice, order updates, or styling input.</p>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Vastrini" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Designed for women who want ease with edge" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Every edit is curated to look elevated, feel effortless, and arrive beautifully. A softer luxury mood, built for everyday dressing.</p>" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Explore collections" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F9F2EF" }
  ],
  "presets": [{ "name": "Features banner" }]
}
{% endschema %}
