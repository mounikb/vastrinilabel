<section class="section features-section" style="background:{{ section.settings.bg_color }}">
  <div class="features-banner">
    <div class="page-width">
      <div class="features-banner__stats" aria-label="Brand promises">
        <article class="features-stat">
          <span class="features-stat__icon">{% render 'icon', icon: 'diamond' %}</span>
          <strong>100%</strong>
          <span class="features-stat__label">Handpicked quality</span>
          <p>Every piece curated to perfection</p>
        </article>
        <article class="features-stat">
          <span class="features-stat__icon">{% render 'icon', icon: 'truck' %}</span>
          <strong>2-5 Days</strong>
          <span class="features-stat__label">Pan-India delivery</span>
          <p>Fast, insured &amp; tracked</p>
        </article>
        <article class="features-stat">
          <span class="features-stat__icon">{% render 'icon', icon: 'shield' %}</span>
          <strong>256-bit</strong>
          <span class="features-stat__label">Secure checkout</span>
          <p>Industry-leading encryption</p>
        </article>
        <article class="features-stat">
          <span class="features-stat__icon">{% render 'icon', icon: 'headset' %}</span>
          <strong>24/7</strong>
          <span class="features-stat__label">Styling support</span>
          <p>Real help, via WhatsApp</p>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features banner",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F9F2EF" }
  ],
  "presets": [{ "name": "Features banner" }]
}
{% endschema %}
